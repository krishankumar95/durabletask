<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net48;net10.0</TargetFrameworks>
    <AssemblyName>DurableTask.ServiceFabric</AssemblyName>
    <RootNamespace>DurableTask.ServiceFabric</RootNamespace>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>sign.snk</AssemblyOriginatorKeyFile>

    <!-- NuGet package metadata -->
    <PackageId>ServiceBus.DurableTask.ServiceFabric</PackageId>
    <Version>1.0.1-delta1</Version>
    <Title>ServiceBus.DurableTask.ServiceFabric</Title>
    <Authors>pradeek;shsama</Authors>
    <Description>Service fabric based storage provider for Durable Task Framework.
This package was generated from vnext_servicefabric branch and is for private use of Azure ServiceBus team.</Description>
    <Copyright>Copyright © 2016</Copyright>
    <PackageTags>ServiceFabric Azure Task Durable Orchestration Workflow Activity Reliable</PackageTags>
  </PropertyGroup>

  <!-- .NET Framework: exact same package versions as original charlie9 build -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net48'">
    <PackageReference Include="Microsoft.ServiceFabric" Version="5.5.216" />
    <PackageReference Include="Microsoft.ServiceFabric.Data" Version="2.5.216" />
    <PackageReference Include="Microsoft.ServiceFabric.Services" Version="2.5.216" />
    <PackageReference Include="Newtonsoft.Json" Version="8.0.3" />
    <PackageReference Include="System.Collections.Immutable" Version="1.2.0" />
    <PackageReference Include="Microsoft.Diagnostics.Tracing.EventSource.Redist" Version="1.1.28" />
  </ItemGroup>

  <!-- .NET 10: modern package versions with netstandard2.0 support -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Microsoft.ServiceFabric.Data" Version="6.0.1004" />
    <PackageReference Include="Microsoft.ServiceFabric.Services" Version="6.0.1004" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Collections.Immutable" Version="1.7.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DurableTask.Framework\DurableTask.Framework.csproj" />
  </ItemGroup>
</Project>