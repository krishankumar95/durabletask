<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net48;net10.0</TargetFrameworks>
    <AssemblyName>DurableTaskFx</AssemblyName>
    <RootNamespace>DurableTask</RootNamespace>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>sign.snk</AssemblyOriginatorKeyFile>
    <!-- Suppress obsolete formatter-based serialization warnings on .NET 10 — 
         we keep GetObjectData overrides for backward compatibility with existing serialized state -->
    <NoWarn>$(NoWarn);SYSLIB0051;CS0672</NoWarn>

    <!-- NuGet package metadata -->
    <PackageId>ServiceBus.DurableTask</PackageId>
    <Version>1.0.1-delta1</Version>
    <Title>Durable Task Framework</Title>
    <Authors>affandar;siport;shsama</Authors>
    <Description>This package provides a C# based durable Task framework for writing long running applications.
This package was generated from vnext_servicefabric branch and is for private use of Azure ServiceBus team.</Description>
    <Copyright>Copyright 2013</Copyright>
    <PackageTags>ServiceBus Service Bus Azure Task Durable Orchestration Workflow Activity Reliable</PackageTags>
  </PropertyGroup>

  <!-- Files that exist on disk but are stale/incompatible — excluded from original legacy project too -->
  <ItemGroup>
    <Compile Remove="DecisionTask.cs" />
    <Compile Remove="TaskWorker.cs" />
    <Compile Remove="TaskOrchestrationClient.cs" />
    <Compile Remove="OrchestratorAction\OrchestrationCompleteDecision.cs" />
    <Compile Remove="ServiceBus\PartitionedQueue.cs" />
    <Compile Remove="Tracing\OrchestrationEtwListener.cs" />
  </ItemGroup>

  <!-- .NET Framework: exact same package versions as original charlie9 build -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net48'">
    <PackageReference Include="ImpromptuInterface" Version="6.2.2" />
    <PackageReference Include="Newtonsoft.Json" Version="8.0.3" />
    <PackageReference Include="WindowsAzure.ServiceBus" Version="3.1.7" />
    <PackageReference Include="WindowsAzure.Storage" Version="7.0.0" />
    <Reference Include="System.Transactions" />
    <Reference Include="System.Runtime.Serialization" />
    <Reference Include="System.Xml.Linq" />
  </ItemGroup>

  <!-- .NET 10: modern package versions with netstandard2.0 support -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="ImpromptuInterface" Version="7.0.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.Runtime.Serialization.Primitives" Version="4.3.0" />
  </ItemGroup>
</Project>